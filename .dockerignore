# =============================================================================
# Docker Ignore - FundLens Backend
# =============================================================================

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Build outputs
dist
coverage
.nyc_output

# Development files
.git
.gitignore
.env
.env.*
!.env.example

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~

# Test files
test
tests
*.spec.ts
*.test.ts
jest.config.js
test/

# Documentation
*.md
!README.md
docs/
COMPREHENSIVE_SYNONYM_EXPANSION.yaml

# Local development
local-s3-storage
logs
*.log

# Infrastructure (not needed in container)
infrastructure/
.kiro/
rebuild-specs/

# Scripts (deployment scripts not needed in container)
scripts/

# Python parser (built separately, but keep config files needed by backend)
python_parser/
!python_parser/xbrl_parsing/
!python_parser/xbrl_parsing/metric_mapping_enhanced.yaml

# Large files that should never be in the image
*.pdf
*.docx
*.xlsx
*.pptx
FUTURE/
DEPLOYMENT/

# Misc
.DS_Store
Thumbs.db
*.tgz
*.tar.gz
