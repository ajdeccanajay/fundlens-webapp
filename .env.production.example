# =============================================================================
# FundLens Production Environment Configuration
# =============================================================================
# IMPORTANT: This is an example file. Do NOT commit actual secrets!
# In production, use AWS Secrets Manager for sensitive values.
# =============================================================================

# Application
NODE_ENV=production
PORT=3000

# Database (retrieved from Secrets Manager in ECS)
# DATABASE_URL is injected from AWS Secrets Manager
# Format: postgresql://user:password@host:5432/database?sslmode=require

# Python Parser (sidecar container)
PYTHON_PARSER_URL=http://localhost:8000

# AWS Configuration
AWS_REGION=us-east-1
# AWS credentials are provided via ECS Task Role (no keys needed)

# S3 Buckets
S3_BUCKET_NAME=fundlens-documents-dev
S3_DATA_LAKE_BUCKET=fundlens-data-lake
BEDROCK_CHUNKS_BUCKET=fundlens-bedrock-chunks

# Bedrock Knowledge Base
BEDROCK_KB_ID=NB5XNMHBQT
BEDROCK_DATA_SOURCE_ID=OQMSFOE5SL

# Lambda
KB_SYNC_LAMBDA_NAME=bedrock-kb-sync

# Cognito (retrieved from Secrets Manager in ECS)
COGNITO_USER_POOL_ID=us-east-1_4OYqnpE18
COGNITO_REGION=us-east-1
# COGNITO_APP_CLIENT_ID is injected from AWS Secrets Manager
# COGNITO_APP_CLIENT_SECRET is injected from AWS Secrets Manager

# Platform Admin (retrieved from Secrets Manager in ECS)
# PLATFORM_ADMIN_KEY is injected from AWS Secrets Manager

# SEC API Configuration
SEC_USER_AGENT=FundLensAI/1.0 (contact: ops@fundlens.ai)
REQUEST_DELAY_MS=150
CACHE_TTL_MS=86400000

# Disable mock services in production
USE_MOCK_S3=false

# Document Intelligence Pipeline — Vision Extraction
# Set to 'true' on ECS (16GB+ memory). Keep 'false' on local dev (4GB limit).
ENABLE_VISION_EXTRACTION=true

# Background Enrichment Pipeline
ENABLE_BACKGROUND_ENRICHMENT=true
ENRICHMENT_DELAY_MS=5000
ENRICHMENT_CONCURRENCY_GUARD=false
ENABLE_VISION_EXTRACTION=true
